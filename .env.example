# Copy this to .env.development (for local dev) or .env.production (for deploys)
# Next.js automatically loads the right file based on NODE_ENV:
#   npm run dev    → .env.development
#   next build     → .env.production

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Server only (never expose to browser/client)
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
SUPABASE_DB_PASSWORD=<your-db-password>
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Required for the expiration sweep cron endpoint
EXPIRATION_SWEEP_SECRET=<your-secret>
